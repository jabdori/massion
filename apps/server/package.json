{
  "name": "@massion/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "massion-server": "./dist/main.js"
  },
  "scripts": {
    "build": "pnpm build-deps && node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "build-deps": "pnpm --filter @massion/application build",
    "test": "pnpm build && vitest run src",
    "typecheck": "pnpm build-deps && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@massion/application": "workspace:*",
    "@massion/governance": "workspace:*",
    "@massion/identity": "workspace:*",
    "@massion/organization": "workspace:*",
    "@massion/storage": "workspace:*",
    "@massion/work": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
