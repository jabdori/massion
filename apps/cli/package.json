{
  "name": "@massion/cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "massion": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm build-deps && node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "build-deps": "pnpm --filter @massion/application build && pnpm --filter @massion/runtime exec tsc -p tsconfig.json",
    "test": "pnpm build && vitest run src --maxWorkers=1",
    "typecheck": "pnpm build-deps && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@massion/application": "workspace:*",
    "@massion/runtime": "workspace:*",
    "@massion/subscriptions": "workspace:*",
    "commander": "15.0.0"
  },
  "devDependencies": {
    "@massion/governance": "workspace:*",
    "@massion/identity": "workspace:*",
    "@massion/organization": "workspace:*",
    "@massion/storage": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
