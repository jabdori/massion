{
  "name": "@massion/software-engineering",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "build-deps": "pnpm --filter @massion/assurance build && pnpm --filter @massion/evidence build",
    "test": "pnpm build-deps && pnpm build && vitest run src",
    "typecheck": "pnpm build-deps && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@massion/assurance": "workspace:*",
    "@massion/evidence": "workspace:*",
    "@massion/identity": "workspace:*",
    "@massion/organization": "workspace:*",
    "@massion/runtime": "workspace:*",
    "@massion/storage": "workspace:*",
    "@massion/work": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
