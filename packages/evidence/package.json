{
  "name": "@massion/evidence",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "test": "pnpm --filter @massion/identity build && vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@massion/identity": "workspace:*",
    "@massion/storage": "workspace:*",
    "@vscode/tree-sitter-wasm": "0.3.1",
    "chokidar": "5.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
