{
  "name": "@massion/assurance",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "test": "pnpm --filter @massion/work... build && vitest run src",
    "typecheck": "pnpm --filter @massion/work... build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@massion/governance": "workspace:*",
    "@massion/identity": "workspace:*",
    "@massion/storage": "workspace:*",
    "@massion/work": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
