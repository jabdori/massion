{
  "name": "@massion/runtime",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "test": "pnpm --filter @massion/identity build && pnpm --filter @massion/organization exec tsc -p tsconfig.json && pnpm --filter @massion/subscriptions build && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@ai-sdk/anthropic": "3.0.96",
    "@ai-sdk/openai": "3.0.83",
    "@ai-sdk/openai-compatible": "2.0.59",
    "@ai-sdk/provider": "3.0.14",
    "@ai-sdk/provider-utils": "4.0.38",
    "@anthropic-ai/claude-agent-sdk": "0.3.207",
    "@anthropic-ai/sdk": "0.111.0",
    "@massion/identity": "workspace:*",
    "@massion/organization": "workspace:*",
    "@massion/router": "workspace:*",
    "@massion/storage": "workspace:*",
    "@massion/subscriptions": "workspace:*",
    "@openai/codex-sdk": "0.144.1",
    "@voltagent/core": "2.9.0",
    "@voltagent/logger": "2.0.2",
    "ai": "6.0.222",
    "ai-sdk-provider-claude-code": "4.0.1",
    "graphql": "16.14.2",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
