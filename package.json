{
  "name": "massion",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "@opentelemetry/core": "2.8.0",
      "uuid": "11.1.1"
    }
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "node --test scripts/*.test.mjs && pnpm -r --workspace-concurrency=1 test",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify:docs",
    "verify:docs": "node scripts/verify-docs.mjs",
    "verify:architecture": "node scripts/verify-architecture-diagrams.mjs",
    "verify:security": "node scripts/verify-security.mjs",
    "verify:hardening": "pnpm --filter @massion/server build && vitest run apps/server/src/registry-fuzz.test.ts apps/server/src/main.e2e.test.ts apps/server/src/operation-queue.test.ts apps/server/src/extension-supervision.test.ts packages/router/src/failure.test.ts packages/storage/src/backup.test.ts && node scripts/hardening-load.mjs",
    "release:evidence": "node scripts/release-evidence.mjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "eslint": "10.6.0",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
